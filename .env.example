# Backend
# Leave DATABASE_URL empty to use backend/filing_counter.db automatically.
# For GPU/server deployments, prefer an absolute SQLite path if you set it:
# DATABASE_URL=sqlite:////home/ubuntu-test1/INTERNS/anvesha/Filing_counter/backend/filing_counter.db
DATABASE_URL=
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8030
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=4000
FRONTEND_BACKEND_URL=http://127.0.0.1:8030

# OCR flow:
# 1. PaddleOCR is the primary scanner OCR engine.
# 2. Tesseract is used only when Paddle is unavailable, fails, or returns weak text.
LOCAL_OCR_ENABLED=true
LOCAL_OCR_DPI=220
LOCAL_OCR_PRIMARY_ENGINE=paddle
LOCAL_OCR_FALLBACK_ENGINE=tesseract
LOCAL_OCR_MIN_CONFIDENCE=0.55
PADDLE_OCR_LANG=en
PADDLE_OCR_USE_GPU=false
TESSERACT_CMD=

# Vision fallback:
# Used for targeted pages such as cause title / party details / vakalatnama /
# lower-court pages, especially when OCR is Hindi, handwritten, or garbled.
FILING_VISION_ENABLED=true
FILING_VISION_TARGET_KEY_PAGES=true
FILING_VISION_OLLAMA_URL=http://127.0.0.1:11434
FILING_VISION_MODEL=llama3.2-vision
FILING_VISION_MAX_PAGES=100
FILING_VISION_TIMEOUT_SECONDS=180
FILING_VISION_RENDER_DPI=200
